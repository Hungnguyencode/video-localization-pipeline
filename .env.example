# Do not commit your real API key to public GitHub.
# Copy this file to .env and paste your key below.
FPT_AI_API_KEY=your_fpt_ai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

FPT_MAX_WAIT_SEC=45
FPT_MAX_RETRIES=1
FPT_CHUNK_CHARS=90
FPT_MIN_CHUNK_CHARS=35
FPT_FALLBACK_TO_EDGE=1
FPT_FALLBACK_EDGE_VOICE=vi-VN-HoaiMyNeural
EDGE_MAX_RETRIES=8

TTS_VALIDATE_TARGET_DURATION=1
TTS_MIN_TARGET_RATIO=0.25
TTS_MIN_AUDIO_MS=450
TTS_MIN_NONSILENT_MS=250
TTS_SILENCE_THRESH_DB=-45

AUDIO_ALIGN_STRICT_TIMELINE=1
AUDIO_ALIGN_MAX_SPEEDUP=1.65
AUDIO_ALIGN_PADDING_MS=30
AUDIO_ALIGN_MIN_GAP_MS=20
AUDIO_ALIGN_TRIM_SILENCE=1